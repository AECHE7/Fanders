{
    "name": "libraryvault/library-management",
    "description": "Library Management System",
    "type": "project",
    "require": {
        "php": ">=7.4",
        "setasign/fpdf": "^1.8",
        "supabase/supabase-php": "^0.0.1",
        "vlucas/phpdotenv": "^5.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    }
    ,
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "robmorgan/phinx": "^0.12.7"
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    }
    ,
    "scripts": {
        "migrate": "vendor/bin/phinx migrate",
        "migrate:rollback": "vendor/bin/phinx rollback"
    }
}
